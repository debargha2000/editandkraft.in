rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for all unspecified documents
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // PROJECTS COLLECTION - Public Read, Admin Write
    // ==========================================
    match /projects/{projectId} {
      // Public can read projects (portfolio display)
      allow read: if true;
      
      // Only authenticated admins can create
      allow create: if isAuthenticated() && isAdmin() && 
                       validateProjectCreation(request.resource.data);
      
      // Only authenticated admins can update their own projects
      allow update: if isAuthenticated() && isAdmin() && 
                       validateProjectUpdate(request.resource.data) &&
                       validateUpdateFields(request.resource.data);
      
      // Only authenticated admins can delete
      allow delete: if isAuthenticated() && isAdmin();
      
      // Subcollection for project history (audit trail)
      match /history/{historyId} {
        allow read: if isAuthenticated() && isAdmin();
        allow create: if isAuthenticated() && isAdmin();
      }
    }
    
    // ==========================================
    // ADMINS COLLECTION - Admin Only
    // ==========================================
    match /admins/{adminId} {
      allow read: if isAdmin() && (resource.id == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    // ==========================================
    // AUDIT LOGS COLLECTION - Admin Read Only
    // ==========================================
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Created by Cloud Functions only
    }
    
    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is admin (email-based)
    function isAdmin() {
      return request.auth.token.email in [
        'debarghapakhira@gmail.com',
        'deys87714@gmail.com'
      ];
    }
    
    // Validate project creation data
    function validateProjectCreation(data) {
      return data.keys().hasAll(['title', 'category', 'timestamp']) &&
             isString(data.title) && data.title.size() > 0 && data.title.size() <= 200 &&
             isString(data.category) && data.category.size() > 0 &&
             isString(data.description ?? '') && data.description.size() <= 2000 &&
             isString(data.imageUrl ?? '') &&
             isString(data.link ?? '') &&
             data.timestamp == request.time;
    }
    
    // Validate project update data
    function validateProjectUpdate(data) {
      return data.keys().hasAll(['title', 'category']) &&
             isString(data.title) && data.title.size() > 0 && data.title.size() <= 200 &&
             isString(data.category) && data.category.size() > 0 &&
             isString(data.description ?? '') && data.description.size() <= 2000 &&
             isString(data.imageUrl ?? '') &&
             isString(data.link ?? '');
    }
    
    // Validate that only allowed fields are updated
    function validateUpdateFields(data) {
      let allowedFields = ['title', 'category', 'description', 'imageUrl', 'link'];
      return !data.keys().hasAny(['timestamp', 'createdAt']) &&
             data.keys().toSet().difference(allowedFields.toSet()).size() == 0;
    }
    
    // Check if value is string
    function isString(value) {
      return value is string;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // ==========================================
    // STORAGE RULES - Images and Media
    // ==========================================
    
    // Default deny all first
    match /{allPaths=**} {
      allow read: if isPublicResource(allPaths);
      allow write: if false;
    }
    
    // Projects folder - public read, admin write
    match /projects/{imageId} {
      allow read: if true; // Public read for portfolio images
      allow write: if isAuthenticated() && isAdmin() && 
                      validateProjectImage(resource);
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // Temporary uploads folder - admin only
    match /temp/{tempId} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin() && 
                      request.resource.size < 10 * 1024 * 1024; // 10MB limit
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // ==========================================
    // STORAGE HELPER FUNCTIONS
    // ==========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth.token.email in [
        'debarghapakhira@gmail.com',
        'deys87714@gmail.com'
      ];
    }
    
    // Check if resource is public (images)
    function isPublicResource(path) {
      return path.matches(/^projects\/.+/);
    }
    
    // Validate project image
    function validateProjectImage(resource) {
      let validTypes = ['image/jpeg', 'image/png', 'image/webp'];
      return resource.size < 5 * 1024 * 1024 && // 5MB max
             resource.contentType in validTypes &&
             isValidImageName(resource.name);
    }
    
    // Validate image filename
    function isValidImageName(name) {
      return name.matches(/^[a-zA-Z0-9_-]+\.(jpg|jpeg|png|webp)$/i);
    }
  }
}