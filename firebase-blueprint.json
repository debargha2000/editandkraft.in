{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project documented by the agency",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Display title of the project" },
        "client": { "type": "string", "description": "The client for whom the project was done" },
        "year": { "type": "string", "description": "Year of completion" },
        "description": { "type": "string", "description": "Detailed project description" },
        "category": { "type": "string", "enum": ["Social Media", "Motion Graphics", "YouTube", "Short-Form"] },
        "projectUrl": { "type": "string", "format": "uri", "description": "Link to the external work" },
        "imageUrl": { "type": "string", "format": "uri", "description": "Thumbnail image from storage" },
        "color": { "type": "string", "description": "Brand or accent hex color" },
        "isFavorite": { "type": "boolean", "description": "Whether to showcase on home page" },
        "showcaseSlot": { "type": "number", "description": "Ordering slot for home page (1-6)" },
        "showcaseLabel": { "type": "string", "description": "Custom overlay label for showcase" },
        "timestamp": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects collection"
    }
  }
}
